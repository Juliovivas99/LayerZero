# Environment Variables Example
# Copy this file to .env.local for local development

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://layerzero.studio

# Stripe (required for checkout)
# Use sk_test_/pk_test_ + test Price IDs for local testing; sk_live_/pk_live_ for production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_BUILD=price_...
STRIPE_PRICE_PARTNERSHIP=price_...

# Optional: for client-side Stripe (e.g. billing portal)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Email Service (Resend)
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=
# Email address to receive contact form submissions
CONTACT_EMAIL=julio@layerzero.studio

# Analytics (optional)
# NEXT_PUBLIC_GA_ID=
